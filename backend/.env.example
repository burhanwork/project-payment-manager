# Copy this file to .env and fill in real values before starting the server.

# MongoDB connection string (the code reads MONGO_URI).
MONGO_URI=mongodb://localhost:27017/project_payment_manager

# Secret used to sign JWTs. Use a long, random string.
# The server refuses to start if this is missing.
JWT_SECRET=replace-with-a-long-random-string

# Port the API/Socket.io server listens on.
PORT=3003
